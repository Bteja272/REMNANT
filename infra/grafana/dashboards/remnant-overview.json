{
  "uid": "remnant-overview",
  "title": "REMNANT System Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(remnant_api_http_requests_total[1m]))",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Actions Submitted",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(remnant_api_actions_submitted_total)",
          "legendFormat": "actions"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Worker Events Processed",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(remnant_worker_events_processed_total)",
          "legendFormat": "events"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "C++ Engine Executions",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(remnant_worker_consequence_engine_total{engine=\"cpp\"})",
          "legendFormat": "cpp"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Actions by Type",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (action_type) (rate(remnant_worker_events_processed_total[1m]))",
          "legendFormat": "{{action_type}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Consequence Engine Usage",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (engine) (rate(remnant_worker_consequence_engine_total[1m]))",
          "legendFormat": "{{engine}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Worker Processing Duration p95",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(remnant_worker_processing_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "API Request Rate by Route",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (route) (rate(remnant_api_http_requests_total[1m]))",
          "legendFormat": "{{route}}"
        }
      ]
    }
  ]
}